# Symphony runtime configuration.
# Copy to .env locally or export these in your shell before starting Symphony.

# Linear: Settings -> Security & access -> Personal API keys.
LINEAR_API_KEY=

# Git clone URL used by Symphony when it creates per-issue workspaces.
# For local smoke tests before a GitHub remote exists:
# SOURCE_REPO_URL=file:///Users/canersevince/gameproject
# For normal use:
# SOURCE_REPO_URL=git@github.com:your-org/gameproject.git
SOURCE_REPO_URL=

# Optional: keep workspaces outside the repo if preferred.
SYMPHONY_WORKSPACE_ROOT=/Users/canersevince/gameproject/.symphony/workspaces

# Optional: override the Codex binary used by Symphony.
CODEX_BIN=codex

# Game server local admin seed.
# These are unsafe placeholders; override them locally and never commit real credentials.
# If either GAME_ADMIN_EMAIL or GAME_ADMIN_PASSWORD is set, both are required.
GAME_ADMIN_EMAIL=
GAME_ADMIN_PASSWORD=
GAME_ADMIN_CALLSIGN=Admin
