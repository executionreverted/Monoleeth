{
  "name": "space-morpg-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "node tests/client-lint.mjs",
    "bundle-scan": "npm run build && node tests/bundle-scan.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:phase09-map": "node tests/e2e/phase09-map-flow.mjs",
    "e2e:phase10-pvp-death": "node tests/e2e/phase10-pvp-death-flow.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run bundle-scan"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
